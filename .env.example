# ===========================================
# Xray Checker (kutovoys/xray-checker)
# ===========================================

# Subscription URL(s) (required)
# Multiple URLs can be specified using comma as delimiter
# Example: SUBSCRIPTION_URL=https://url1/sub,https://url2/sub,https://url3/sub
SUBSCRIPTION_URL=https://your-subscription-url/sub

# Metrics protection
METRICS_PROTECTED=false
METRICS_USERNAME=
METRICS_PASSWORD=

# Checker tuning
PROXY_CHECK_INTERVAL=300
PROXY_CHECK_METHOD=ip
PROXY_TIMEOUT=30
CHECKER_LOG_LEVEL=info

# Port to expose checker on host (2112 = default)
CHECKER_EXTERNAL_PORT=2112

# ===========================================
# Xray Analyzer (this project)
# ===========================================

# Xray Checker API — внутри docker-compose используйте имя контейнера
# Извне: http://localhost:2112
# Из контейнера analyzer: http://xray-checker:2112
CHECKER_API_URL=http://xray-checker:2112
CHECKER_API_USERNAME=
CHECKER_API_PASSWORD=

# Diagnostics
DNS_TIMEOUT=5
TCP_TIMEOUT=5
TUNNEL_TEST_URL=https://httpbin.org/ip
TUNNEL_TEST_ENABLED=true

# Check-Host.net API (optional, for DNS comparison)
# Get your API key at https://check-host.net
CHECK_HOST_API_KEY=

# Proxy Status/IP Check URLs
PROXY_STATUS_CHECK_URL=http://cp.cloudflare.com/generate_204
PROXY_IP_CHECK_URL=https://api.ipify.org?format=text

# RKN Check (rknweb.ru API часто недоступен — по умолчанию выключен)
RKN_API_URL=https://rknweb.ru/api
RKN_CHECK_ENABLED=false

# Proxy SNI Check
PROXY_SNI_TEST_ENABLED=true
PROXY_SNI_DOMAIN=max.ru

# RKN Throttle Check (detects 16-20KB DPI blocking)
RKN_THROTTLE_CHECK_ENABLED=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=xray-analyzer.log

# Notifications
NOTIFY_TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Scheduling
CHECK_INTERVAL_SECONDS=300

# Analysis scope (false = only offline proxies)
ANALYZE_ONLINE_PROXIES=false

# Xray Core for VLESS/Trojan/SS testing
# If not found in PATH, will be auto-downloaded from GitHub releases
XRAY_BINARY_PATH=xray
XRAY_TEST_ENABLED=true
SUBSCRIPTION_URL=              # Subscription URL with VLESS/Trojan/SS share links
SUBSCRIPTION_HWID=             # HWID header (x-hwid) for subscription (if required)
