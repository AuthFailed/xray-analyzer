# ===========================================
# Xray Analyzer
# ===========================================

# Diagnostics
DNS_TIMEOUT=5
TCP_TIMEOUT=5
TUNNEL_TEST_URL=https://httpbin.org/ip
TUNNEL_TEST_ENABLED=true

# Check-Host.net API (optional, for DNS comparison)
# Get your API key at https://check-host.net
CHECK_HOST_API_KEY=

# Proxy Status/IP Check URLs
PROXY_STATUS_CHECK_URL=http://cp.cloudflare.com/generate_204
PROXY_IP_CHECK_URL=https://api.ipify.org?format=text

# Proxy SNI Check
PROXY_SNI_TEST_ENABLED=true
PROXY_SNI_DOMAIN=max.ru

# RKN Throttle Check (detects 16-20KB DPI blocking)
RKN_THROTTLE_CHECK_ENABLED=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=xray-analyzer.log

# Notifications
NOTIFY_TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Scheduling
CHECK_INTERVAL_SECONDS=300

# Xray Core for VLESS/Trojan/SS testing
# If not found in PATH, will be auto-downloaded from GitHub releases
XRAY_BINARY_PATH=xray
XRAY_TEST_ENABLED=true
SUBSCRIPTION_HWID=             # HWID header (x-hwid) for subscription (if required)

# Censor-Check / Scan Mode (test web resources for blocking)
# Comma-separated list of domains (empty = use default list of ~30 domains)
CENSOR_CHECK_DOMAINS=
# Timeout per domain in seconds
CENSOR_CHECK_TIMEOUT=4
# Maximum parallel checks
CENSOR_CHECK_MAX_PARALLEL=10
# Proxy URL for checking (empty = direct connection)
# Example: socks5://127.0.0.1:1080 or http://proxy.example.com:8080
CENSOR_CHECK_PROXY_URL=

# ===========================================
# Metrics server (serve command)
# ===========================================

# Prometheus /metrics endpoint — scraped by Prometheus, Grafana, etc.
# Inside docker-compose the port is exposed as METRICS_EXTERNAL_PORT → 9090
METRICS_HOST=0.0.0.0
METRICS_PORT=9090

# Host port to expose the metrics server on (docker-compose only)
METRICS_EXTERNAL_PORT=9090

# ===========================================
# Monitoring stack (monitoring profile)
# docker-compose --profile monitoring up
# ===========================================

# Prometheus host port (internal port is always 9090)
PROMETHEUS_EXTERNAL_PORT=9091

# Grafana host port and credentials
GRAFANA_EXTERNAL_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
